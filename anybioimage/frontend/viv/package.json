{
  "name": "anybioimage-viv-bundle",
  "version": "0.7.0-alpha.0",
  "private": true,
  "description": "Viv + zarrita.js rendering bundle for anybioimage",
  "type": "module",
  "scripts": {
    "build": "node build.config.mjs",
    "size": "size-limit"
  },
  "dependencies": {
    "@hms-dbmi/viv": "0.17.3",
    "zarrita": "0.5.1",
    "deck.gl": "9.0.38",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "esbuild": "0.25.0",
    "size-limit": "11.1.6",
    "@size-limit/esbuild": "11.1.6",
    "@size-limit/file": "11.1.6"
  },
  "overrides": {
    "@luma.gl/core": "9.0.28",
    "@luma.gl/engine": "9.0.28",
    "@luma.gl/webgl": "9.0.28",
    "@luma.gl/shadertools": "9.0.28",
    "@luma.gl/constants": "9.0.28",
    "@deck.gl/extensions": "9.0.38",
    "@deck.gl/mesh-layers": "9.0.38"
  },
  "size-limit": [
    {
      "path": "dist/viv-bundle.js",
      "limit": "3 MB"
    }
  ]
}
